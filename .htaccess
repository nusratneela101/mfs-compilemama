# MFS Compilemama — Apache Configuration

# Enable mod_rewrite
Options -Indexes +FollowSymLinks
RewriteEngine On

# Force HTTPS (uncomment in production)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove trailing slash (except for directory)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# Block access to sensitive directories/files
RewriteRule ^config/     - [F,L]
RewriteRule ^logs/       - [F,L]
RewriteRule ^sql/        - [F,L]
RewriteRule ^\.          - [F,L]

# Block direct access to include files
<FilesMatch "\.(php)$">
    <If "getenv('SCRIPT_FILENAME') =~ m|/includes/|">
        Order Deny,Allow
        Deny from all
    </If>
</FilesMatch>

# Protect config files
<FilesMatch "(config\.php|database\.php|location\.php)">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Block access to admin_header/admin_footer directly
<FilesMatch "^admin_(header|footer)\.php$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Security Headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png  "access plus 1 month"
    ExpiresByType image/jpg  "access plus 1 month"
    ExpiresByType text/css   "access plus 1 week"
    ExpiresByType text/javascript "access plus 1 week"
</IfModule>

# PHP Settings
<IfModule mod_php.c>
    php_value upload_max_filesize 5M
    php_value post_max_size 6M
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
    php_value session.cookie_samesite Strict
</IfModule>

# Custom error pages
ErrorDocument 403 /index.php
ErrorDocument 404 /index.php
ErrorDocument 500 /index.php
